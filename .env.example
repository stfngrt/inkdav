# ============================================================
# TRMNL Week Calendar – Environment Configuration
# ============================================================
# Copy to .env and fill in your values.

# ── BYOS (larapaper) ─────────────────────────────────────────
# Generate with: php artisan key:generate --show  (or any 32-char random string)
BYOS_APP_KEY=base64:CHANGE_ME

# LAN IP of the host machine so devices can reach the BYOS UI
LOCAL_IP=192.168.1.100

# ── Calendar sidecar ─────────────────────────────────────────
# Calendars are managed exclusively via the web UI at http://localhost:5000
# No calendar config belongs here.
